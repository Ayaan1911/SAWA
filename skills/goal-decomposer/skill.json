{
  "name": "goal-decomposer",
  "version": "1.0.0",
  "description": "Turn active goals into confidence-weighted next actions that are small enough for a single focus block.",
  "endpoint": "http://localhost:3000/skills/goal-decomposer",
  "method": "POST",
  "input": {
    "type": "object",
    "properties": {
      "input": { "type": "string" },
      "context": { "type": "object" }
    },
    "required": ["input"]
  },
  "output": {
    "type": "object",
    "properties": {
      "output": { "type": "string" },
      "actions": { "type": "array" },
      "timestamp": { "type": "string" }
    }
  }
}
